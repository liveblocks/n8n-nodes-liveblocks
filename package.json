{
	"name": "n8n-nodes-liveblocks",
	"version": "0.1.6",
	"description": "Official Liveblocks n8n community nodes",
	"license": "MIT",
	"homepage": "https://liveblocks.io",
	"keywords": [
		"n8n-community-node-package",
		"liveblocks",
		"collaboration",
		"realtime",
		"storage",
		"ai",
		"yjs",
		"comments",
		"notifications",
		"hitl"
	],
	"author": {
		"name": "Liveblocks, Inc. - Jonathan Rowny",
		"email": "jonathan.rowny@liveblocks.io"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/liveblocks/n8n-nodes-liveblocks"
	},
	"scripts": {
		"build": "n8n-node build",
		"generate:client": "npx --yes @hey-api/openapi-ts@0.94.3 -i https://raw.githubusercontent.com/liveblocks/liveblocks/refs/heads/main/docs/references/v2.openapi.json -o nodes/Liveblocks/client && node scripts/patch-openapi-codegen.mjs",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"format": "prettier nodes credentials --write",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/LiveblocksApi.credentials.js",
			"dist/credentials/LiveblocksWebhookSigningSecretApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Liveblocks/Liveblocks.node.js",
			"dist/nodes/Liveblocks/LiveblocksTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.32.0",
		"prettier": "^3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
